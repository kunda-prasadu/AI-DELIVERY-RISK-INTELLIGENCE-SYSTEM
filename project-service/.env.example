# Project Service — Environment Variables
# Copy to .env and fill in values before running

PORT=3002
NODE_ENV=development

# JWT secret — MUST match identity-service JWT_SECRET so tokens are accepted cross-service
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Risk scoring weights (must sum to 1.0)
WEIGHT_CODE_VELOCITY=0.25
WEIGHT_QUALITY=0.30
WEIGHT_CICD=0.25
WEIGHT_JIRA_VELOCITY=0.20
