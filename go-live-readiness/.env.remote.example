# Use these overrides for staging/production live checks.
# readiness-check.js reads these when running: npm run check:live

IDENTITY_HEALTH_URL=https://staging.example.com/identity/health
PROJECT_HEALTH_URL=https://staging.example.com/projects/health
OBSERVABILITY_HEALTH_URL=https://staging.example.com/observability/health/live
METRICS_HEALTH_URL=https://staging.example.com/metrics/health/live
GATEWAY_HEALTH_URL=https://staging.example.com/gateway/health

# smoke-check.js reads this when running: npm run smoke
GATEWAY_BASE_URL=https://staging.example.com
