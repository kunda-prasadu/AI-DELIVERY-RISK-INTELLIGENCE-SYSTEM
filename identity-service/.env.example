# ── Identity Service Environment Variables ─────────────────────────────────
# Copy to .env — never commit real values.

NODE_ENV=development
PORT=3001

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
