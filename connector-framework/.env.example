# ── Connector Framework Environment Variables ──────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

NODE_ENV=development

# ── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEYS=PROJ1,PROJ2          # comma-separated project keys to monitor

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_ORG=your-github-org             # GitHub org or username
GITHUB_REPOS=repo1,repo2               # comma-separated repos

# ── QA / Test Management ────────────────────────────────────────────────────
QA_TOOL=testng                          # testng | jest | allure | custom
QA_REPORT_URL=http://your-qa-server/api
QA_API_TOKEN=your_qa_api_token

# ── CI/CD ────────────────────────────────────────────────────────────────────
CICD_PROVIDER=github_actions            # github_actions | jenkins | gitlab
CICD_API_URL=https://api.github.com    # override for Jenkins/GitLab
CICD_TOKEN=your_cicd_token

# ── Queue settings ────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_MS=2000
DLQ_MAX_SIZE=500

# ── Cron schedules (cron syntax) ─────────────────────────────────────────────
CRON_JIRA=*/15 * * * *
CRON_GITHUB=*/10 * * * *
CRON_QA=0 * * * *
CRON_CICD=*/5 * * * *

# ── Downstream event bus (optional) ──────────────────────────────────────────
DOWNSTREAM_WEBHOOK_URL=http://localhost:4000/events
